# ===================================================
# Variáveis de Ambiente - TEMPLATE
# ===================================================
# Copie este arquivo para .env.local e preencha os valores

# ===================================================
# SUPABASE
# ===================================================
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=seu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=seu_service_role_key_aqui

# ===================================================
# SINCRONIZAÇÃO WC2026 API
# ===================================================
# Token para autorizar requisições ao /api/sync-games
# Gere um valor aleatório com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SYNC_TOKEN=seu_token_secreto_aleatorio_aqui

# Token para autorizar requisições ao /api/cron (do Vercel)
CRON_SECRET=outro_token_secreto_aleatorio_para_cron

# URL da aplicação (necessário em produção para chamar sync internamente)
# Em desenvolvimento, deixe vazio ou use http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
